{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "Your InfluxDB ev_twin datasource",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "title": "EV Digital Twin",
  "uid":   "ev-twin-capstone",
  "tags":  ["ev", "digital-twin", "ml"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "State of Charge (LSTM)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0   },
              { "color": "orange", "value": 10  },
              { "color": "green",  "value": 20  }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: -1m) |> filter(fn: (r) => r._measurement == \"soc_model\" and r._field == \"predicted_soc\") |> last()"
      }]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "State of Health",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 70, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "green",  "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: -10m) |> filter(fn: (r) => r._measurement == \"soh_model\" and r._field == \"soh_pct\") |> last()"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Range estimate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": { "unit": "lengthkm" }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: -1m) |> filter(fn: (r) => r._measurement == \"range_model\" and r._field == \"range_km\") |> last()"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Anomaly score",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "orange", "value": 0.7 },
              { "color": "red",    "value": 1.0 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: -1m) |> filter(fn: (r) => r._measurement == \"anomaly\" and r._field == \"error_ratio\") |> last()"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SoC — LSTM corrected vs Coulomb counting",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"soc_model\" and r._field == \"predicted_soc\")",
          "legendFormat": "LSTM SoC"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"battery\" and r._field == \"soc\")",
          "legendFormat": "Coulomb SoC"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Battery temperature with alert threshold",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "celsius" },
        "overrides": [{
          "matcher": { "id": "byName", "options": "temperature" },
          "properties": [{
            "id": "thresholds",
            "value": {
              "steps": [
                { "color": "green",  "value": 0  },
                { "color": "orange", "value": 40 },
                { "color": "red",    "value": 55 }
              ]
            }
          }]
        }]
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"battery\" and r._field == \"temperature\")",
        "legendFormat": "Temperature"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Anomaly reconstruction error (log scale)",
      "gridPos": { "x": 0, "y": 14, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "scaleDistribution": { "type": "log", "log": 10 } }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"anomaly\" and r._field == \"global_error\")",
          "legendFormat": "Reconstruction error"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"anomaly\" and r._field == \"threshold\")",
          "legendFormat": "Alert threshold"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Fault alert log",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 8 },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart) |> filter(fn: (r) => r._measurement == \"anomaly_alert\" and r._field == \"global_error\") |> keep(columns: [\"_time\", \"likely_fault\", \"severity\", \"_value\"]) |> rename(columns: {_value: \"error\", _time: \"time\"}) |> sort(columns: [\"time\"], desc: true) |> limit(n: 20)"
      }],
      "fieldConfig": {
        "overrides": [{
          "matcher": { "id": "byName", "options": "severity" },
          "properties": [{
            "id": "custom.displayMode",
            "value": "color-text"
          }]
        }]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "SoH degradation over cycles",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 70, "max": 102 }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "from(bucket: \"ev_twin\") |> range(start: -7d) |> filter(fn: (r) => r._measurement == \"soh_model\" and r._field == \"soh_pct\") |> aggregateWindow(every: 5m, fn: last) |> fill(usePrevious: true)"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Range estimate — static vs dynamic blend",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "lengthkm" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"range_model\" and r._field == \"range_km\")",
          "legendFormat": "Blended range"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"range_model\" and r._field == \"static_km\")",
          "legendFormat": "Static estimate"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"ev_twin\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"range_model\" and r._field == \"dynamic_km\")",
          "legendFormat": "Dynamic estimate"
        }
      ]
    }
  ]
}
